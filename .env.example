# AI GitHub Repository Analyzer — Environment Configuration
# Copy this to .env and fill in your keys.

# Gemini API Key (recommended primary AI provider)
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# GitHub API Token (required for batch analysis and rich RL state)
# Generate at: https://github.com/settings/tokens (no special scopes needed for public repos)
GITHUB_TOKEN=

# Groq API Key (fallback AI provider after Gemini)
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API Key (final fallback AI provider)
OPENAI_API_KEY=

# Optional: Model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_MODEL=gpt-4o-mini

# Port for the worker process (default: 3001)
# WORKER_PORT=3001
