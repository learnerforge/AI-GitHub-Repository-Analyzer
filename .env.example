# Gemini API Key (recommended)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model to use (default: gemini-2.0-flash)
# Options: gemini-2.0-flash, gemini-2.5-pro, gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.0-flash

# GitHub API Token (optional for batch analyzer, enables richer RL state)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OpenAI API Key (fallback if Gemini is not set)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Port for the worker process (default: 3001)
WORKER_PORT=3001
